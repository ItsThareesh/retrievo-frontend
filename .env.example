APP_ENV=development # Change this to production for enabling domain restrictions for signup

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXTAUTH_SECRET= # Added by `npx auth`

# Required by Auth.js
AUTH_TRUST_HOST=true

# Public backend URL used by browser -> backend API calls (client-side)
# In dev: http://localhost:8000/api/v1
# In prod: Change it to your actual backend URL
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000/api/v1"

# This is deliberately pointed to localhost for local dev. It's overridden in Docker Compose
INTERNAL_BACKEND_URL="http://localhost:8000/api/v1"

# Added to request headers to eliminate unwanted requests
INTERNAL_SECRET_KEY=

